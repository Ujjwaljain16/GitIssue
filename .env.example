APP_NAME=git-issue-tracker
APP_ENV=dev
GITHUB_WEBHOOK_SECRET=replace_me
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM=github_events
REDIS_GROUP=workers
WORKER_CONSUMER=worker-1
WORKER_BLOCK_MS=5000
WORKER_BATCH_SIZE=10
WORKER_RETRY_MAX_ATTEMPTS=5
WORKER_RECLAIM_IDLE_MS=30000
WORKER_RECLAIM_COUNT=20
REDIS_DEAD_LETTER_STREAM=github_events_dlq
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/issues
